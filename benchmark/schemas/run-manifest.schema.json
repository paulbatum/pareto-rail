{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-manifest.schema.json",
  "title": "Pareto Rail benchmark run manifest",
  "description": "Documentary contract for a complete v2 run record as written by run.mjs createManifest. Keep records private until blind rankings are locked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "benchmarkVersion",
    "runId",
    "slotId",
    "configuration",
    "theme",
    "baseline",
    "recipe",
    "controller",
    "timing",
    "stages",
    "cost",
    "gates",
    "output",
    "disposition"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "benchmarkVersion": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "slotId": { "type": "string", "minLength": 1 },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "theme": { "$ref": "#/$defs/themeArtifact" },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["materialsCommit", "entrantBaseline"],
      "properties": {
        "materialsCommit": { "$ref": "#/$defs/gitObject" },
        "entrantBaseline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier"],
          "properties": {
            "kind": { "const": "git-commit" },
            "identifier": { "$ref": "#/$defs/gitObject" }
          }
        },
        "guard": {
          "description": "Result of the entrant-baseline structural check, evaluated at launch under every policy. Absent means the run predates the guard being recorded; present with an empty `violations` means it ran and found nothing.",
          "type": "object",
          "additionalProperties": false,
          "required": ["policy", "violations"],
          "properties": {
            "policy": { "enum": ["open", "scrubbed"] },
            "violations": {
              "description": "Structural exposures in the baseline tree. A scrubbed policy aborts the launch on any of these, so a scrubbed run's list is always empty; an open policy records them and proceeds.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path", "reason"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "recipe": { "$ref": "#/$defs/hashedArtifact" },
    "controller": {
      "description": "Executing controller checkout provenance.",
      "$ref": "#/$defs/controllerProvenance"
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "finishedAt", "wallTimeSeconds"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "wallTimeSeconds": { "type": "number", "minimum": 0 }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "status", "orchestrationTreatment"],
      "properties": {
        "currency": { "const": "USD" },
        "status": { "enum": ["measured", "unavailable"] },
        "totalUsd": { "type": "number", "minimum": 0 },
        "unavailableReason": { "type": "string", "minLength": 1 },
        "orchestrationTreatment": {
          "enum": ["included", "excluded", "already-included", "none", "unavailable"]
        },
        "costSource": {
          "description": "Tool and version that computed the cost. ccusage prices the persisted rollouts (parent plus any delegated subagents) with its own maintained rate DB.",
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "version"],
          "properties": {
            "tool": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "view": { "type": "string", "minLength": 1 },
            "command": { "type": "string", "minLength": 1 }
          }
        },
        "models": {
          "description": "Per-model detail from the cost source. Cost is present when the source attributes it per model (Claude); Codex reports per-model tokens only, so costUsd is omitted there.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modelName", "inputTokens", "outputTokens"],
            "properties": {
              "modelName": { "type": "string", "minLength": 1 },
              "costUsd": { "type": "number", "minimum": 0 },
              "inputTokens": { "type": "integer", "minimum": 0 },
              "outputTokens": { "type": "integer", "minimum": 0 },
              "cacheReadTokens": { "type": "integer", "minimum": 0 },
              "cacheWriteTokens": { "type": "integer", "minimum": 0 },
              "reasoningTokens": { "type": "integer", "minimum": 0 },
              "usageSource": { "description": "Which source this row's tokens and cost came from; `agreed` means both matched.", "enum": ["ccusage", "harness-counter", "agreed"] }
            }
          }
        },
        "reconciliation": {
          "description": "Cross-check of the cost source against the harness's own per-model counter. Transcript replay can under-report output when an assistant message never finalized on disk; the counter tallies API responses as they arrive. The direction of a gap decides which source is wrong: a counter above replay is replay having lost a message, while a counter below replay means it did not cover the whole session and replay stands.",
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "description": "`agreed`: sources match. `adjusted`: counter preferred where it exceeded replay. `suspect`: a counter came in below replay and was not used. `unavailable`: the harness reports no counter.", "enum": ["agreed", "adjusted", "suspect", "unavailable"] },
            "source": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 },
            "adjustments": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["modelName", "replayOutputTokens", "counterOutputTokens", "resolution"],
                "properties": {
                  "modelName": { "type": "string", "minLength": 1 },
                  "replayOutputTokens": { "type": "integer", "minimum": 0 },
                  "counterOutputTokens": { "type": "integer", "minimum": 0 },
                  "replayCostUsd": { "type": "number", "minimum": 0 },
                  "counterCostUsd": { "type": "number", "minimum": 0 },
                  "resolution": { "enum": ["took-counter", "kept-replay"] }
                }
              }
            }
          }
        }
      },
      "allOf": [
        { "if": { "properties": { "status": { "const": "measured" } } }, "then": { "required": ["totalUsd"] } },
        { "if": { "properties": { "status": { "const": "unavailable" } } }, "then": { "required": ["unavailableReason"] } }
      ]
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    },
    "output": { "$ref": "#/$defs/output" },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "enum": ["playable", "dnf", "controller-failure", "rehearsal"] },
        "reasonCode": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "gitObject": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "controllerProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit"],
      "properties": {
        "commit": { "$ref": "#/$defs/gitObject" }
      }
    },
    "hashedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "themeArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["levelId", "title", "evaluated"],
      "properties": {
        "sourceRoot": { "enum": ["src/levels", "src/benchmark-levels"] },
        "levelId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "evaluated": {
          "description": "Exact registered working tree used for mechanical gates and blind play.",
          "$ref": "#/$defs/outputCommit"
        },
        "payload": {
          "description": "Derived commit based on the materials commit that contains only the assigned level directory under the source root.",
          "$ref": "#/$defs/outputCommit"
        }
      }
    },
    "outputCommit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit"],
      "properties": {
        "commit": { "$ref": "#/$defs/gitObject" },
        "branch": { "type": "string", "minLength": 1 }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "snapshotId"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "snapshotId": { "type": "string", "minLength": 1 }
      }
    },
    "harness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputTokens", "outputTokens"],
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "cacheReadInputTokens": { "type": "integer", "minimum": 0 },
        "cacheWriteInputTokens": { "type": "integer", "minimum": 0 },
        "reasoningTokens": { "type": "integer", "minimum": 0 },
        "vendorFields": {
          "type": "object",
          "description": "Unmodified additional numeric usage fields reported by the provider.",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "enum": ["measured", "unavailable"] },
        "costUsd": { "type": "number", "minimum": 0 },
        "source": {
          "description": "How this stage's cost was computed. ccusage-sourced stages carry no per-token rates.",
          "type": "string",
          "minLength": 1
        },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        { "if": { "properties": { "status": { "const": "measured" } } }, "then": { "required": ["costUsd"] } },
        { "if": { "properties": { "status": { "const": "unavailable" } } }, "then": { "required": ["reason"] } }
      ]
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "model", "harness", "sessionId", "startedAt", "finishedAt", "wallTimeSeconds", "usage", "pricing", "result"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": { "enum": ["orchestrate", "implement", "solo"] },
        "model": { "$ref": "#/$defs/model" },
        "harness": { "$ref": "#/$defs/harness" },
        "sessionId": { "type": "string", "minLength": 1 },
        "promptSha256": { "$ref": "#/$defs/sha256" },
        "delegationPromptSha256": { "$ref": "#/$defs/sha256" },
        "budget": { "$ref": "#/$defs/budgetSummary" },
        "inputArtifactSha256": { "$ref": "#/$defs/sha256" },
        "outputArtifactSha256": { "$ref": "#/$defs/sha256" },
        "rolloutArtifactSha256": { "$ref": "#/$defs/sha256" },
        "continuationRounds": { "type": "integer", "minimum": 1 },
        "entrantSandbox": { "type": "boolean" },
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "wallTimeSeconds": { "type": "number", "minimum": 0 },
        "usage": { "$ref": "#/$defs/usage" },
        "pricing": { "$ref": "#/$defs/pricing" },
        "result": { "enum": ["completed", "failed", "timed-out"] }
      }
    },
    "budgetSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budgetUsd", "protocol", "noticeHistory", "resumes", "finalSpendUsd", "finalFraction"],
      "properties": {
        "budgetUsd": { "type": "number", "exclusiveMinimum": 0 },
        "protocol": {
          "type": "object",
          "additionalProperties": false,
          "required": ["noticeStepPct", "minimumSubmitFraction", "maxResumeRounds", "pollIntervalSeconds", "minimumResumeRemainingSeconds"],
          "properties": {
            "noticeStepPct": { "const": 25 },
            "minimumSubmitFraction": { "const": 0.75 },
            "maxResumeRounds": { "enum": [3, 20] },
            "pollIntervalSeconds": { "const": 30 },
            "minimumResumeRemainingSeconds": { "const": 600 }
          }
        },
        "noticeHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pct", "spentUsd", "at"],
            "properties": {
              "pct": { "type": "integer", "minimum": 25, "multipleOf": 25 },
              "spentUsd": { "type": "number", "minimum": 0 },
              "at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "resumes": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["round", "spentUsd", "fraction", "startedAt", "finishedAt", "exitCode"],
            "properties": {
              "round": { "type": "integer", "minimum": 1, "maximum": 3 },
              "spentUsd": { "type": "number", "minimum": 0 },
              "fraction": { "type": "number", "minimum": 0 },
              "startedAt": { "type": "string", "format": "date-time" },
              "finishedAt": { "type": "string", "format": "date-time" },
              "exitCode": { "type": "integer" }
            }
          }
        },
        "finalSpendUsd": { "type": "number", "minimum": 0 },
        "finalFraction": { "type": "number", "minimum": 0 }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "status", "wallTimeSeconds"],
      "properties": {
        "id": { "enum": ["typecheck", "build", "scope", "floor"] },
        "command": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "not-run"] },
        "exitCode": { "type": "integer" },
        "wallTimeSeconds": { "type": "number", "minimum": 0 },
        "outputSha256": { "$ref": "#/$defs/sha256" },
        "reason": { "type": "string" }
      }
    }
  }
}

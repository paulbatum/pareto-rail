{
  "name": "pareto-rail",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-icons.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "prisma generate && npm run validate:level-catalog && node scripts/check-serverless-imports.mjs && node scripts/check-no-tracked-png.mjs && vite build && node scripts/generate-social-heroes.mjs && node scripts/prerender-heads.mjs && node scripts/generate-sitemap.mjs && node scripts/check-bundle-budget.mjs",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "check:serverless-imports": "node scripts/check-serverless-imports.mjs",
    "check:scope": "node scripts/check-benchmark-scope.mjs",
    "check:benchmark-scope": "node scripts/check-benchmark-scope.mjs",
    "snapshot": "node scripts/snapshot.mjs",
    "snapshot:gameplay": "node scripts/gameplay-snapshot.mjs",
    "trace:audio": "node scripts/audio-trace.mjs",
    "trace:spawns": "node scripts/spawn-trace.mjs",
    "simulate": "node scripts/simulate.mjs",
    "check:floor": "node scripts/check-floor.mjs",
    "check:perf": "node scripts/check-perf.mjs",
    "check:occlusion": "node scripts/target-occlusion.mjs",
    "scaffold": "node scripts/scaffold-level.mjs",
    "gallery": "node scripts/collect-gallery.mjs",
    "validate:level-catalog": "node scripts/validate-level-catalog.mjs",
    "benchmark:render": "node scripts/benchmark/render-assignment.mjs",
    "benchmark:ranking": "node scripts/benchmark/ranking.mjs",
    "benchmark:admin": "node scripts/benchmark/admin.mjs",
    "benchmark:codex": "node scripts/benchmark/codex-cli.mjs",
    "benchmark:claude": "node scripts/benchmark/claude-cli.mjs",
    "benchmark:pi": "node scripts/benchmark/pi-cli.mjs",
    "benchmark:run": "node scripts/benchmark/run.mjs",
    "benchmark:cut-baseline": "node scripts/benchmark/cut-baseline.mjs",
    "benchmark:results": "node scripts/benchmark/results.mjs",
    "benchmark:status": "node scripts/benchmark/status.mjs",
    "benchmark:manage": "node scripts/benchmark/manage-run.mjs",
    "benchmark:promote": "node scripts/benchmark/promote.mjs",
    "benchmark:restore-src": "node scripts/benchmark/restore-src.mjs",
    "benchmark:catalog": "node scripts/benchmark/catalog.mjs",
    "benchmark:thumbnails": "node scripts/benchmark/generate-thumbnails.mjs",
    "benchmark:export-rank-catalog": "node scripts/benchmark/export-rank-catalog.mjs",
    "benchmark:export-provenance": "node scripts/benchmark/export-provenance.mjs",
    "benchmark:export-rollouts": "node scripts/benchmark/export-rollouts.mjs",
    "benchmark:reconcile-cost": "node scripts/benchmark/reconcile-cost.mjs",
    "benchmark:contamination": "node scripts/benchmark/detect-contamination.mjs",
    "test:benchmark-catalog": "node scripts/benchmark/test-catalog.mjs",
    "test:benchmark-controller": "node scripts/benchmark/test.mjs",
    "test:benchmark-baseline": "node scripts/benchmark/test-baseline.mjs",
    "test:benchmark-budget": "node scripts/benchmark/test-budget.mjs",
    "test:benchmark-quota-wait": "node scripts/benchmark/test-quota-wait.mjs",
    "test:benchmark-contamination": "node scripts/benchmark/test-contamination.mjs",
    "test:benchmark-promotion": "node scripts/benchmark/test-promotion.mjs",
    "test:benchmark-domain": "node --experimental-strip-types --experimental-loader ./scripts/benchmark/ts-extension-loader.mjs src/benchmark/domain.test.ts",
    "test:vote-api": "node --experimental-strip-types --experimental-loader ./scripts/benchmark/ts-extension-loader.mjs scripts/benchmark/test-vote-api.ts",
    "test:benchmark-level-domain": "node --experimental-strip-types --experimental-loader ./scripts/benchmark/ts-extension-loader.mjs src/benchmark-levels/domain.test.ts",
    "sim:crystal-debug": "node scripts/run-crystal-debug-sim.mjs",
    "sim:crystal-debug:verbose": "node scripts/run-crystal-debug-sim.mjs --verbose"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-virtual": "^3.14.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge": "^1.3.1",
    "@vercel/og": "^0.6.8",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ccusage": "20.0.17",
    "prisma": "^7.8.0",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "typescript": "latest",
    "vite": "latest"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "freeze.schema.json",
  "title": "raild benchmark freeze record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "benchmarkVersion",
    "frozenAt",
    "materialsCommit",
    "entrantBaseline",
    "artifacts",
    "harnesses"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "benchmarkVersion": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*$"
    },
    "frozenAt": { "type": "string", "format": "date-time" },
    "materialsCommit": { "$ref": "#/$defs/gitObject" },
    "entrantBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "identifier"],
      "properties": {
        "kind": { "enum": ["git-commit", "archive"] },
        "identifier": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256"],
        "properties": {
          "kind": {
            "enum": [
              "prompt",
              "theme",
              "recipe",
              "controller-runbook",
              "runner",
              "schema",
              "decision-rule",
              "ranking-protocol",
              "run-schedule",
              "pricing"
            ]
          },
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "harnesses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "details": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "gitObject": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    }
  }
}

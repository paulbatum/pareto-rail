{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-schedule.schema.json",
  "title": "Pareto Rail private benchmark run schedule",
  "description": "Confidential append-only assignment ledger and slot-to-configuration mapping. Existing rows stay immutable when configurations are added. Keep private until the relevant blind ranking snapshot is locked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "benchmarkVersion",
    "generatedAt",
    "randomization",
    "assignments"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "benchmarkVersion": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "randomization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method"],
      "properties": {
        "method": { "enum": ["cryptographic-shuffle", "seeded-shuffle"] },
        "seed": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/assignment" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hashedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "gitObject": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduleIndex",
        "runId",
        "slotId",
        "configurationId",
        "configurationCommit",
        "recipe",
        "stage",
        "theme",
        "levelId",
        "levelTitle"
      ],
      "properties": {
        "scheduleIndex": { "type": "integer", "minimum": 1 },
        "runId": {
          "description": "Opaque internal identifier that must not encode model, configuration, theme, or execution order.",
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{3,63}$"
        },
        "slotId": {
          "description": "Opaque public identifier that must not encode model, configuration, or execution order.",
          "type": "string",
          "pattern": "^[a-z0-9]{4}$"
        },
        "configurationId": { "type": "string", "minLength": 1 },
        "configurationCommit": { "$ref": "#/$defs/gitObject" },
        "runner": {
          "description": "Legacy v1 field tolerated when reading historical schedules; new schedules omit it.",
          "$ref": "#/$defs/hashedArtifact"
        },
        "executor": {
          "description": "Legacy v1 field tolerated when reading historical schedules; new schedules omit it.",
          "$ref": "#/$defs/hashedArtifact"
        },
        "recipe": { "$ref": "#/$defs/hashedArtifact" },
        "stage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "model", "effort", "timeoutSeconds"],
          "properties": {
            "adapter": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "effort": { "enum": ["low", "medium", "high", "xhigh", "max", "ultra"] },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "budget": {
              "type": "object",
              "additionalProperties": false,
              "required": ["usd"],
              "properties": {
                "usd": { "type": "number", "exclusiveMinimum": 0 }
              }
            }
          }
        },
        "theme": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "path", "sha256"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "levelId": {
          "description": "Globally unique implementation id, conventionally <theme-id>-<slot-id>.",
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "levelTitle": {
          "description": "Player-facing title taken from the assigned theme's first level-one heading; it must not reveal configuration, model, slot, or schedule position.",
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

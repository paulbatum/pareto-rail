{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ranking-snapshot.schema.json",
  "title": "Pareto Rail ranking snapshot",
  "description": "An immutable lock record for one analysis snapshot. Later configurations create a later snapshot rather than rewriting this one.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "benchmarkVersion", "snapshotId", "method", "schedule", "records", "lockedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "benchmarkVersion": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "method": { "enum": ["ranked-set", "pairwise"] },
    "schedule": { "$ref": "#/$defs/artifact" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "lockedAt": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}

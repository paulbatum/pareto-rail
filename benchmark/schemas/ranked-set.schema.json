{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ranked-set.schema.json",
  "title": "Pareto Rail blind ranked set",
  "description": "One theme's anonymous entrants ranked into ordered tiers. Slots in the same tier are tied.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "benchmarkVersion", "rankingId", "themeId", "slotIds", "presentationOrder", "playCounts", "tiers", "recordedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "benchmarkVersion": { "type": "string", "minLength": 1 },
    "rankingId": { "type": "string", "minLength": 1 },
    "themeId": { "type": "string", "minLength": 1 },
    "slotIds": { "$ref": "#/$defs/slots" },
    "presentationOrder": { "$ref": "#/$defs/slots" },
    "playCounts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slotId", "count"],
        "properties": {
          "slotId": { "type": "string", "pattern": "^[a-z0-9]{4}$" },
          "count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "tiers": {
      "description": "Best-to-worst tiers; every slot appears exactly once, enforced by the controller validator.",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slots" }
    },
    "notes": { "type": "string" },
    "recordedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "slots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]{4}$" }
    }
  }
}
